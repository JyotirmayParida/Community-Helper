rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isVerifier() {
      return hasRole('verifier');
    }

    // Config Collection
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Departments Collection
    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isVerifier());
      // A user can create/update their own profile, or admin can manage all
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if isSignedIn();
      // Any signed-in user can create a report, but the citizenId must match their auth UID
      allow create: if isSignedIn() && 
        request.resource.data.citizenId == request.auth.uid &&
        request.resource.data.status == 'submitted';
      
      // Citizens can update their own reports if not yet resolved, or admins/verifiers can update status
      allow update: if isSignedIn() && (
        isAdmin() || 
        isVerifier() || 
        (resource.data.citizenId == request.auth.uid && resource.data.status == 'submitted')
      );
      allow delete: if isAdmin();
    }
  }
}
